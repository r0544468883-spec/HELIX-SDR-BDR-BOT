# ── HELIX SDR-BDR-BOT — Environment ──────────────────────────────

# Firecrawl (own-layer scrape engine — waterfall layer 1)
# https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-api-key-here

# Anthropic Claude — THE LLM (all enrichment + research + generation runs on Claude).
# Used via Anthropic's OpenAI-compat endpoint (see lib/helix/llm.ts). This is the only key the LLM needs.
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
CLAUDE_MODEL=claude-sonnet-5                 # quality tier — research + message generation
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001  # fast tier — high-volume extract/classify/corroborate

# OpenAI — NO LONGER USED (base migrated to Claude). Leave blank.
OPENAI_API_KEY=

# Supabase (own DB — accounts/contacts/enrichment_fields; connects to Product 02 dashboards)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Ollama (optional — local model for high-volume low-stakes tasks: classify, embeddings, dedup)
# Leave blank to route everything to Claude. See spec Model Router.
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3.5:4b

# Product 02 (HELIX Dashboards) connection — metrics push target
HELIX_DASHBOARDS_URL=
HELIX_DASHBOARDS_KEY=

# Enable unlimited mode (dev)
FIRE_ENRICH_UNLIMITED=true
NODE_ENV=development
